{
  "name": "admatix",
  "private": true,
  "version": "0.1.0",
  "description": "AdMatix — the evidence-gated operating layer for humans and AI agents running paid media.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck && tsc -p tsconfig.json",
    "test": "vitest run",
    "setup:python": "node scripts/python-services.mjs setup all",
    "setup:python:core": "node scripts/python-services.mjs setup core",
    "setup:python:verifier": "node scripts/python-services.mjs setup verifier",
    "setup:python:validation": "node scripts/python-services.mjs setup validation",
    "test:python": "pnpm run test:python:core && pnpm run test:python:verifier && pnpm run test:python:validation",
    "test:python:core": "node scripts/python-services.mjs test core",
    "test:python:verifier": "node scripts/python-services.mjs test verifier",
    "test:python:validation": "node scripts/python-services.mjs test validation",
    "lint": "turbo run lint",
    "doctor": "tsx scripts/doctor.ts",
    "seed-fixtures": "tsx scripts/seed-fixtures.ts",
    "scan-secrets": "tsx scripts/scan-secrets.ts",
    "audit:prod": "pnpm audit --prod --audit-level=moderate",
    "demo": "tsx scripts/demo.ts"
  },
  "devDependencies": {
    "@admatix/agents": "workspace:*",
    "@admatix/api": "workspace:*",
    "@admatix/connectors": "workspace:*",
    "@admatix/core": "workspace:*",
    "@admatix/evals": "workspace:*",
    "@admatix/evidence": "workspace:*",
    "@admatix/mcp-server": "workspace:*",
    "@admatix/policy": "workspace:*",
    "@admatix/schemas": "workspace:*",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.0",
    "turbo": "^2.1.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "pg": "^8.21.0"
  }
}
