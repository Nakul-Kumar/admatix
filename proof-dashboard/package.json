{
  "name": "admatix-proof-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Standalone showcase dashboard for AdMatix evidence-gated verification.",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run sync:artifacts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "sync:artifacts": "node scripts/sync-proof-artifacts.mjs",
    "validate:origin": "npm run sync:artifacts && node scripts/validate-data-origin.mjs",
    "check:data": "npm run sync:artifacts && node scripts/check-dashboard-data.mjs",
    "check:render": "node scripts/check-dashboard-render.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.13.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.6.2",
    "vite": "^8.0.14"
  }
}
