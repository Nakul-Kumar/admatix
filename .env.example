# AdMatix environment. Copy to .env.local. NEVER commit real values.
ADMATIX_ENV=local
ADMATIX_MODE=fixtures            # fixtures | live  — MVP runs entirely on fixtures
DATABASE_URL=postgres://localhost:5432/admatix

# Platform credentials are READ-ONLY and optional until Phase 7.
# Leave blank for the 72-hour MVP — the build runs on data/fixtures/.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
META_ADS_ACCESS_TOKEN=

# LLM provider. The agent layer is model-agnostic and the MVP uses a
# deterministic rules engine — no key is required to build or demo.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ADMATIX_LLM_PROVIDER=none        # none | anthropic | openai
