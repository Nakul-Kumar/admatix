{
  "name": "admatix",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "admatix": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "admatix": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "cli": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@admatix/agents": "workspace:*",
    "@admatix/connectors": "workspace:*",
    "@admatix/core": "workspace:*",
    "@admatix/evals": "workspace:*",
    "@admatix/evidence": "workspace:*",
    "@admatix/policy": "workspace:*",
    "@admatix/schemas": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
